# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# internal-only: the bot's source-of-truth brief. Contains the comp floor,
# honest weaknesses, rebuff pool phrasings, and other material that should
# not ship in a public repo. Deployed separately (see notes below).
PROFILE_BRIEF.md

# defensive: scratch/temp files that occasionally show up during local work
*.tmp
*.bak
*.swp
*.swo

# resumes, headshots, and any other personal artifacts dropped at the root
/Jared-Malcolm-*.pdf
/resume*.pdf
/*-headshot.*
